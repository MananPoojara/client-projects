NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_discovery?schema=public"
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=2000
DB_IDLE_TIMEOUT=30000
DB_QUERY_TIMEOUT=10000
DB_LOG_QUERIES=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=job-discovery-api
JWT_AUDIENCE=job-discovery-app

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW=900000
AUTH_RATE_LIMIT_MAX=5
RATE_LIMIT_MESSAGE=Too many requests, please try again later

# File Upload
MAX_FILE_SIZE=5242880
MAX_FILES=10
UPLOAD_STORAGE=local
UPLOAD_LOCAL_PATH=./uploads

# Cloud Storage (optional)
CLOUD_PROVIDER=
CLOUD_BUCKET=
CLOUD_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
CSRF_ENABLED=false
HSTS_MAX_AGE=31536000
CSP_ENABLED=true
REFERRER_POLICY=strict-origin-when-cross-origin

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_FILE_PATH=./logs
LOG_MAX_FILES=7
LOG_MAX_SIZE=10m
