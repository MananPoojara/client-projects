generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  head
  senior_staff
  staff
}

enum ApplicationStatus {
  draft
  pending_review
  approved
  rejected
  submitted
}

enum JobType {
  full_time
  part_time
  contract
  internship
  temporary
}

enum RemoteType {
  remote
  hybrid
  onsite
}

enum CandidateStatus {
  active
  inactive
  hired
  withdrawn
}

model Staff {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  role         Role      @default(staff)
  department   String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdCandidates    Candidate[]
  applications         Application[]
  reviewedApplications Application[] @relation("Reviewer")
  activities           StaffActivity[]
  auditLogs            AuditLog[]

  @@map("staff")
}

model Candidate {
  id              String          @id @default(uuid())
  firstName       String          @map("first_name")
  lastName        String          @map("last_name")
  email           String          @unique
  phone           String?
  location        String?
  linkedinUrl     String?         @map("linkedin_url")
  resumePath      String?         @map("resume_path")
  skills          String[]        @default([])
  experienceYears Int?            @map("experience_years")
  currentCompany  String?         @map("current_company")
  currentTitle    String?         @map("current_title")
  status          CandidateStatus @default(active)
  consentGdpr     Boolean         @default(false) @map("consent_gdpr")
  createdBy       String?         @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  createdByStaff Staff?        @relation(fields: [createdBy], references: [id])
  applications  Application[]

  @@map("candidates")
}

model Job {
  id             String      @id @default(uuid())
  title          String
  company        String
  location       String?
  description    String?
  requirements   String[]
  skillsRequired String[]    @default([]) @map("skills_required")
  salaryMin      Int?        @map("salary_min")
  salaryMax      Int?        @map("salary_max")
  sourceUrl      String?     @map("source_url")
  sourcePortal   String?     @map("source_portal")
  jobType        JobType?    @map("job_type")
  remoteType     RemoteType? @map("remote_type")
  status         String      @default("active")
  postedDate     DateTime?   @map("posted_date")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  applications Application[]

  @@index([status])
  @@index([sourcePortal])
  @@index([remoteType])
  @@map("jobs")
}

model Application {
  id           String            @id @default(uuid())
  candidateId  String            @map("candidate_id")
  jobId        String            @map("job_id")
  staffId      String            @map("staff_id")
  coverLetter String?           @map("cover_letter")
  status       ApplicationStatus @default(draft)
  staffNotes   String?           @map("staff_notes")
  reviewerId   String?           @map("reviewer_id")
  reviewedAt   DateTime?         @map("reviewed_at")
  submittedAt  DateTime?         @map("submitted_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  candidate  Candidate @relation(fields: [candidateId], references: [id])
  job        Job       @relation(fields: [jobId], references: [id])
  staff      Staff     @relation(fields: [staffId], references: [id])
  reviewer   Staff?    @relation("Reviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([staffId])
  @@index([candidateId])
  @@map("applications")
}

model StaffActivity {
  id           String   @id @default(uuid())
  staffId      String   @map("staff_id")
  activityType String   @map("activity_type")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([createdAt])
  @@map("staff_activities")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  details     Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user Staff? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  staffId   String   @map("staff_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([staffId])
  @@map("refresh_tokens")
}
